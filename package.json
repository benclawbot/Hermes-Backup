{
  "name": "compliance-checker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node ./scripts/ensure-node-runtime.cjs",
    "prebuild": "node ./scripts/ensure-node-runtime.cjs",
    "pretest": "node ./scripts/ensure-node-runtime.cjs",
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build && npx @opennextjs/cloudflare build --skipNextBuild && cp .open-next/worker.js .open-next/_worker.js && cp -r .open-next/assets/* .open-next/ && printf '{\n  \"version\": 1,\n  \"include\": [\"/*\"],\n  \"exclude\": [\n    \"/_next/static/*\",\n    \"/favicon.ico\",\n    \"/robots.txt\",\n    \"/sitemap.xml\",\n    \"/site.webmanifest\"\n  ]\n}\n' > .open-next/_routes.json",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:coverage": "node ./node_modules/vitest/vitest.mjs run --coverage",
    "test:api:smoke": "node ./scripts/exhaustive-route-smoke.mjs",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "test:exhaustive:local": "bash ./scripts/run-exhaustive-tests.sh",
    "playwright:install": "npx playwright install chromium --with-deps"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@neondatabase/serverless": "^1.0.2",
    "@stripe/stripe-js": "latest",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/pg": "^8.20.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "latest",
    "html2canvas": "^1.4.1",
    "linkedom": "^0.18.12",
    "lucide-react": "latest",
    "next": "latest",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "puppeteer-core": "^24.40.0",
    "react": "latest",
    "react-dom": "latest",
    "server-only": "^0.0.1",
    "tailwind-merge": "latest",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260404.1",
    "@opennextjs/cloudflare": "^1.18.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "latest",
    "@types/nodemailer": "^7.0.11",
    "@types/puppeteer-core": "^5.4.0",
    "@types/react": "latest",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "latest",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  }
}




