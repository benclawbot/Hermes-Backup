# ============================================
# ComplyScan — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- AI: MiniMax (OpenAI-compatible) ---
# Uses MiniMax-M2.5 model. Get your key from api.minimax.io
# Thomas's account key (for local dev only — not for production):
OPENAI_API_KEY=sk-cp-your_minimax_key_here
OPENAI_BASE_URL=https://api.minimax.io/v1

# --- Stripe Payment ---
# 1. Sign up at dashboard.stripe.com
# 2. Get test keys: Developers → API keys → pk_test_... / sk_test_...
# 3. Create products:
#    - "Single Scan" at $29 one-time
#    - "Monthly Monitor" at $99/month recurring
#    - Copy each price_... ID below
# 4. For webhook testing, run: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SINGLE_SCAN=price_...   # $29 one-time
STRIPE_PRICE_MONTHLY=price_...       # $99/month

# --- Email: Resend ---
# Free 100 emails at resend.com. Add domain for custom sender.
# Or use the free testing domain Resend provides.
RESEND_API_KEY=re_...

# --- Database ---
DATABASE_PATH=./data/complyscan.db

# --- Browserless.io (headless Chrome for crawling on Vercel) ---
# Get a free key at browserless.io (10K credits/month free)
# On Vercel: BROWSERLESS_API_KEY is REQUIRED — native fetch fails for external URLs in serverless
# Locally: not needed (uses Puppeteer with system Chrome)
BROWSERLESS_API_KEY=your_browserless_api_key_here

# --- Browser (for local Puppeteer crawler only) ---
# Find path: which chromium-browser  OR  which google-chrome
# On Vercel: leave blank (uses Browserless instead)
CHROME_PATH=/usr/bin/chromium-browser
