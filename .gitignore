# Workspace-wide security + hygiene ignores

# Secrets / credentials
.env
.env.*
!.env.example
*.pem
*.key
*secret*.json
*token*.json
google_client_secret.json
google_tokens.json

# Python artifacts
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# Runtime/state artifacts
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.log
*.log.*
.coverage
htmlcov/

# Local sync/cache noise
.dropbox
.dropbox.cache/

# Keep child projects isolated in their own repos
Projects/

# Local model/cache artifacts
*.pkl

# Path-polluted filenames (from accidental Windows path copies)
*\\*
*:*

# Added by Hermes workspace hardening
.env
.env.*
!.env.example
.netrc
.git-credentials
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
