:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"18\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"19\",{\"property\":\"og:image:alt\",\"content\":\"ComplyScan — GDPR Compliance Scanner\"}],[\"$\",\"meta\",\"20\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"21\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"22\",{\"name\":\"twitter:site\",\"content\":\"@ComplyScan\"}],[\"$\",\"meta\",\"23\",{\"name\":\"twitter:creator\",\"content\":\"@ComplyScan\"}],[\"$\",\"meta\",\"24\",{\"name\":\"twitter:title\",\"content\":\"ComplyScan — Instant GDPR Compliance Checker\"}],[\"$\",\"meta\",\"25\",{\"name\":\"twitter:description\",\"content\":\"Instant automated GDPR compliance scan. No signup required. Get a PDF report in minutes.\"}],[\"$\",\"meta\",\"26\",{\"name\":\"twitter:image\",\"content\":\"https://complyscan.ch/og\"}]],\"error\":null,\"digest\":\"$undefined\"}\n14:\"$f:metadata\"\n"}