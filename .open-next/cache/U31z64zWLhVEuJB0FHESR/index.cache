an\"],\"contactPoint\":{\"@type\":\"ContactPoint\",\"contactType\":\"customer support\",\"availableLanguage\":\"English\"},\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://complyscan.ch?q={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"ComplyScan\",\"applicationCategory\":\"BusinessApplication\",\"operatingSystem\":\"Web\",\"url\":\"https://complyscan.ch\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\",\"description\":\"Free tier with 3 scans per month\"},\"description\":\"AI-powered GDPR compliance scanner that analyses websites and generates PDF audit reports with remediation advice.\",\"aggregateRating\":{\"@type\":\"AggregateRating\",\"ratingValue\":\"4.8\",\"ratingCount\":\"124\",\"bestRating\":\"5\",\"worstRating\":\"1\"}}</script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"font-sans\"><div hidden=\"\"><!--$--><!--/$--></div><main class=\"min-h-screen bg-midnight\"><nav class=\"sticky top-0 z-50 w-full border-b border-white/10 glass\"><div class=\"mx-auto max-w-6xl px-4 sm:px-6 lg:px-8\"><div class=\"flex h-16 items-center justify-between\"><a class=\"font-heading text-xl font-bold text-white hover:text-accent-glow transition-colors\" href=\"/\">ComplyScan</a><div class=\"hidden md:flex items-center gap-8\"><a class=\"text-sm text-white/70 hover:text-white transition-colors\" href=\"#how-it-works\">How it works</a><a class=\"text-sm text-white/70 hover:text-white transition-colors\" href=\"#pricing\">Pricing</a><a class=\"text-sm text-white/70 hover:text-white transition-colors\" href=\"/blog\">Blog</a><a class=\"text-sm text-white/70 hover:text-white transition-colors\" href=\"/login\">Login</a><a class=\"text-sm text-white/70 hover:text-white transition-colors\" href=\"#contact\">Contact</a></div><a class=\"rounded-lg bg-accent-blue px-4 py-2 text-sm font-semibold text-white hover:bg-accent-glow transition-all shadow-lg shadow-accent-blue/25 hover:shadow-accent-blue/40\" href=\"#hero\">Scan Now</a></div></div></nav><section id=\"hero\" class=\"relative min-h-[90vh] flex flex-col items-center justify-center px-4 py-28 text-center overflow-hidden\"><div class=\"absolute inset-0 bg-gradient-to-b from-midnight via-midnight to-midnight-light pointer-events-none\"></div><div class=\"absolute inset-0 bg-[radial-gradient(ellipse_at_50%_0%,rgba(79,142,247,0.12)_0%,transparent_60%)] pointer-events-none\"></div><div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\" style=\"background-image:linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px);background-size:48px 48px\"></div><div class=\"relative z-10 max-w-5xl mx-auto w-full\"><div class=\"inline-flex items-center gap-2 rounded-full border border-accent-blue/20 bg-accent-blue/10 px-4 py-1.5 mb-8 animate-badge-in\"><span class=\"w-1.5 h-1.5 rounded-full bg-accent-blue animate-pulse\"></span><span class=\"text-accent-blue text-xs font-semibold tracking-wider uppercase\">AI-Powered GDPR Scanner</span></div><h1 class=\"font-heading text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-[1.05] mb-6 tracking-tight\" style=\"animation:slide-up 0.6s ease-out both\">Is Your Website<!-- --> <span class=\"relative inline-block\"><span class=\"text-risk-medium\">GDPR</span><span class=\"absolute -bottom-1 left-0 right-0 h-[3px] rounded-full bg-risk-medium/40\"></span></span> <!-- -->Compliant?</h1><p class=\"text-lg sm:text-xl text-white/60 mb-12 max-w-2xl mx-auto leading-relaxed\" style=\"animation:slide-up 0.6s ease-out 0.1s both\">Free GDPR compliance scan in seconds. See every issue before your users do — no credit card, no signup required.</p><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-8 items-start max-w-4xl mx-auto mb-10\" style=\"animation:slide-up 0.6s ease-out 0.2s both\"><div><form class=\"flex flex-col gap-3\"><input type=\"url\" placeholder=\"https://yourwebsite.com\" required=\"\" class=\"rounded-xl bg-midnight-light border border-white/15 px-5 py-4 text-white placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-accent-blue/60 focus:border-accent-blue/40 transition-all text-base\" name=\"url\" value=\"\"/><input type=\"email\" placeholder=\"your@email.com (for your report)\" class=\"rounded-xl bg-midnight-light border border-white/15 px-5 py-4 text-white placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-accent-blue/60 focus:border-accent-blue/40 transition-all text-base\" name=\"email\" value=\"\"/><button type=\"submit\" class=\"rounded-xl bg-accent-blue px-8 py-4 font-bold text-white hover:bg-accent-glow transition-all shadow-glow-blue hover:shadow-blue-500/50 whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed text-base mt-1 hover-scale\">Scan Free →</button></form><p class=\"text-white/25 text-xs mt-3\">3 free scans per month · No credit card needed</p></div><div class=\"glass rounded-2xl p-6 border border-white/10\"><div class=\"flex items-center justify-between mb-4\"><span class=\"text-white/40 text-xs font-semibold uppercase tracking-wider\">Live Demo</span><button class=\"text-white/30 hover:text-white/60 text-xs transition-colors\">Hide</button></div><div class=\"w-full max-w-md mx-auto\"><div class=\"flex flex-col items-center gap-3 py-4\"><div class=\"relative\"><div class=\"absolute inset-0 rounded-full bg-accent-blue/20 animate-ping\" style=\"animation-duration:2s\"></div><div class=\"w-16 h-16 rounded-2xl bg-accent-blue/10 border border-accent-blue/30 flex items-center justify-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield w-8 h-8 text-accent-blue\" aria-hidden=\"true\" style=\"animation:float 3s ease-in-out infinite\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path></svg></div></div><p class=\"text-sm text-white/40\">Ready to scan <!-- -->example.com</p><button class=\"text-xs text-accent-blue hover:text-accent-glow transition-colors underline underline-offset-2\">Start demo scan</button></div></div></div></div><div class=\"flex flex-wrap items-center justify-center gap-8 sm:gap-12 mb-12\" style=\"animation:slide-up 0.6s ease-out 0.3s both\"><div class=\"text-center\"><p class=\"font-heading text-2xl sm:text-3xl font-bold text-white\"><span class=\"\">0<!-- -->+</span></p><p class=\"text-white/40 text-xs mt-0.5 uppercase tracking-wider\">Sites scanned</p></div><div class=\"text-center\"><p class=\"font-heading text-2xl sm:text-3xl font-bold text-white\"><span class=\"\">0<!-- -->.2</span></p><p class=\"text-white/40 text-xs mt-0.5 uppercase tracking-wider\">Avg issues found</p></div><div class=\"text-center\"><p class=\"font-heading text-2xl sm:text-3xl font-bold text-white\"><span class=\"\">0<!-- -->%</span></p><p class=\"text-white/40 text-xs mt-0.5 uppercase tracking-wider\">Uptime</p></div></div><div class=\"mb-8\" style=\"animation:slide-up 0.6s ease-out 0.35s both\"><a class=\"text-sm text-white/35 hover:text-white/60 transition-colors inline-flex items-center gap-1.5\" href=\"/login\">Subscriber dashboard<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-3.5 h-3.5 rotate-[-90deg]\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></a></div></div><div class=\"absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 opacity-30\"><span class=\"text-[10px] uppercase tracking-widest text-white/50\">Scroll</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-4 h-4 text-white/50 animate-bounce\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></div></section><section id=\"how-it-works\" class=\"relative py-28 px-4\"><div class=\"absolute inset-0 bg-gradient-to-b from-midnight-light/20 via-transparent to-transparent pointer-events-none\"></div><div class=\"mx-auto max-w-6xl relative z-10\"><div class=\"reveal  text-center mb-16\"><h2 class=\"font-heading text-3xl sm:text-4xl font-bold text-white mb-4\">Three Steps to Compliance</h2><p class=\"text-white/50 text-lg max-w-xl mx-auto\">From URL to actionable report in under 2 minutes. Fully automated — no manual work.</p></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 relative\"><div class=\"hidden md:block absolute top-[3.25rem] left-[16.67%] right-[16.67%] h-px bg-gradient-to-r from-transparent via-white/10 to-transparent\"></div><div class=\"reveal reveal-delay-1 relative\"><div class=\"glass rounded-2xl p-8 text-center hover-lift border border-white/[0.07] hover:border-white/[0.14] transition-all h-full\"><div class=\"inline-flex items-center justify-center w-8 h-8 rounded-full bg-midnight-light border border-white/10 text-white/40 text-xs font-bold mb-6\">1</div><div class=\"inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-5 relative\" style=\"background:rgba(79,142,247, 0.1);box-shadow:0 0 30px rgba(79,142,247, 0.15)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-link w-8 h-8\" aria-hidden=\"true\" style=\"color:#4f8ef7\"><path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\"></path><path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\"></path></svg></div><h3 class=\"font-heading text-xl font-semibold text-white mb-3\">Enter your URL</h3><p class=\"text-white/50 text-sm leading-relaxed\">Type your website address into our secure scanner. No signup, no account needed — just paste and go.</p></div></div><div class=\"reveal reveal-delay-2 relative\"><div class=\"glass rounded-2xl p-8 text-center hover-lift border border-white/[0.07] hover:border-white/[0.14] transition-all h-full\"><div class=\"inline-flex items-center justify-center w-8 h-8 rounded-full bg-midnight-light border border-white/10 text-white/40 text-xs font-bold mb-6\">2</div><div class=\"inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-5 relative\" style=\"background:rgba(245,158,11, 0.1);box-shadow:0 0 30px rgba(245,158,11, 0.15)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-scan-search w-8 h-8\" aria-hidden=\"true\" style=\"color:#f59e0b\"><path d=\"M3 7V5a2 2 0 0 1 2-2h2\"></path><path d=\"M17 3h2a2 2 0 0 1 2 2v2\"></path><path d=\"M21 17v2a2 2 0 0 1-2 2h-2\"></path><path d=\"M7 21H5a2 2 0 0 1-2-2v-2\"></path><circle cx=\"12\" cy=\"12\" r=\"3\"></circle><path d=\"m16 16-1.9-1.9\"></path></svg></div><h3 class=\"font-heading text-xl font-semibold text-white mb-3\">We scan automatically</h3><p class=\"text-white/50 text-sm leading-relaxed\">Our AI crawler checks 40+ GDPR signals: cookie banners, privacy policies, tracking scripts, SSL, form labels, and third-party embeds.</p></div></div><div class=\"reveal reveal-delay-3 relative\"><div class=\"glass rounded-2xl p-8 text-center hover-lift border border-white/[0.07] hover:border-white/[0.14] transition-all h-full\"><div class=\"inline-flex items-center justify-center w-8 h-8 rounded-full bg-midnight-light border border-white/10 text-white/40 text-xs font-bold mb-6\">3</div><div class=\"inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-5 relative\" style=\"background:rgba(34,197,94, 0.1);box-shadow:0 0 30px rgba(34,197,94, 0.15)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-mail-check w-8 h-8\" aria-hidden=\"true\" style=\"color:#22c55e\"><path d=\"M22 13V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v12c0 1.1.9 2 2 2h8\"></path><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"></path><path d=\"m16 19 2 2 4-4\"></path></svg></div><h3 class=\"font-heading text-xl font-semibold text-white mb-3\">Get your PDF report</h3><p class=\"text-white/50 text-sm leading-relaxed\">Receive a detailed compliance report with every issue, severity rating, legal references, and step-by-step fix guides.</p></div></div></div></div></section><section id=\"what-we-check\" class=\"py-28 px-4 relative\"><div class=\"absolute inset-0 bg-gradient-to-b from-midnight via-midnight to-midnight-light/30 pointer-events-none\"></div><div class=\"mx-auto max-w-6xl relative z-10\"><div class=\"reveal  text-center mb-16\"><div class=\"inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 mb-4\"><span class=\"w-1.5 h-1.5 rounded-full bg-accent-blue animate-pulse\"></span><span class=\"text-white/50 text-xs font-medium uppercase tracking-wider\">40+ audit checks</span></div><h2 class=\"font-heading text-3xl sm:text-4xl font-bold text-white mb-4\">What We Scan For</h2><p class=\"text-white/50 text-lg max-w-xl mx-auto\">Our AI crawler checks every corner of your site against GDPR requirements — automatically.</p></div><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5\"><div class=\"reveal reveal-delay-1\"><div class=\"group glass rounded-2xl p-6 border border-white/[0.07] hover:border-white/[0.14] hover-lift transition-all h-full\"><div class=\"flex items-start gap-4\"><div class=\"flex-shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-xl\" style=\"background:rgba(239,68,68, 0.12);border:1px solid rgba(239,68,68, 0.2)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-cookie w-5 h-5\" aria-hidden=\"true\" style=\"color:#ef4444\"><path d=\"M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5\"></path><path d=\"M8.5 8.5v.01\"></path><path d=\"M16 15.5v.01\"></path><path d=\"M12 12v.01\"></path><path d=\"M11 17v.01\"></path><path d=\"M7 14v.01\"></path></svg></div><div class=\"flex-1 min-w-0\"><div class=\"flex items-center gap-2 mb-1\"><h3 class=\"font-semibold text-white text-sm\">Cookie Consent Banner</h3><span class=\"inline-flex items-center gap-1 text-[10px] font-medium text-white/40\"><span class=\"w-1.5 h-1.5 rounded-full bg-risk-high\"></span>Common violation</span></div><p class=\"text-white/40 text-xs leading-relaxed\">Detects if your site displays a GDPR-compliant cookie consent banner with proper opt-in/opt-out controls.</p></div></div></div></div><div class=\"reveal reveal-delay-2\"><div class=\"group glass rounded-2xl p-6 border border-white/[0.07] hover:border-white/[0.14] hover-lift transition-all h-full\"><div class=\"flex items-start gap-4\"><div class=\"flex-shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-xl\" style=\"background:rgba(239,68,68, 0.12);border:1px solid rgba(239,68,68, 0.2)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-file-text w-5 h-5\" aria-hidden=\"true\" style=\"color:#ef4444\"><path d=\"M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z\"></path><path d=\"M14 2v5a1 1 0 0 0 1 1h5\"></path><path d=\"M10 9H8\"></path><path d=\"M16 13H8\"></path><path d=\"M16 17H8\"></path></svg></div><div class=\"flex-1 min-w-0\"><div class=\"flex items-center gap-2 mb-1\"><h3 class=\"font-semibold text-white text-sm\">Privacy Policy</h3><span class=\"inline-flex items-center gap-1 text-[10px] font-medium text-white/40\"><span class=\"w-1.5 h-1.5 rounded-full bg-risk-high\"></span>Common violation</span></div><p class=\"text-white/40 text-xs leading-relaxed\">Verifies that a privacy policy page exists, is accessible, and covers all required GDPR disclosure items.</p></div></div></div></div><div class=\"reveal reveal-delay-3\"><div class=\"group glass rounded-2xl p-6 border border-white/[0.07] hover:border-white/[0.14] hover-lift transition-all h-full\"><div class=\"flex items-start gap-4\"><div class=\"flex-shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-xl\" style=\"background:rgba(34,197,94, 0.12);border:1px solid rgba(34,197,94, 0.2)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lock w-5 h-5\" aria-hidden=\"true\" style=\"color:#22c55e\"><rect width=\"18\" height=\"11\" x=\"3\" y=\"11\" rx=\"2\" ry=\"2\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"></path></svg></div><div class=\"flex-1 min-w-0\"><div class=\"flex items-center gap-2 mb-1\"><h3 class=\"font-semibold text-white text-sm\">SSL / HTTPS</h3><span class=\"inline-flex items-center gap-1 text-[10px] font-medium text-white/40\"><span class=\"w-1.5 h-1.5 rounded-full bg-risk-low\"></span>Baseline</span></div><p class=\"text-white/40 text-xs leading-relaxed\">Confirms your site uses HTTPS encryption to protect data in transit — baseline for any compliance.</p></div></div></div></div><div class=\"reveal reveal-delay-1\"><div class=\"group glass rounded-2xl p-6 border border-white/[0.07] hover:border-white/[0.14] hover-lift transition-all h-full\"><div class=\"flex items-start gap-4\"><div class=\"flex-shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-xl\" style=\"background:rgba(239,68,68, 0.12);border:1px solid rgba(239,68,68, 0.2)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-eye w-5 h-5\" aria-hidden=\"true\" style=\"color:#ef4444\"><path d=\"M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0\"></path><circle cx=\"12\" cy=\"12\" r=\"3\"></circle></svg></div><div class=\"flex-1 min-w-0\"><div class=\"flex items-center gap-2 mb-1\"><h3 class=\"font-semibold text-white text-sm\">Tracking Scripts</h3><span class=\"inline-flex items-center gap-1 text-[10px] font-medium text-white/40\"><span class=\"w-1.5 h-1.5 rounded-full bg-risk-high\"></span>Common violation</span></div><p class=\"text-white/40 text-xs leading-relaxed\">Identifies Google Analytics, Facebook Pixel, Hotjar, and other ad scripts that require prior user consent.</p></div></div></div></div><div class=\"reveal reveal-delay-2\"><div class=\"group glass rounded-2xl p-6 border border-white/[0.07] hover:border-white/[0.14] hover-lift transition-all h-full\"><div class=\"flex items-start gap-4\"><div class=\"flex-shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-xl\" style=\"background:rgba(245,158,11, 0.12);border:1px solid rgba(245,158,11, 0.2)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-rectangle-ellipsis w-5 h-5\" aria-hidden=\"true\" style=\"color:#f59e0b\"><rect width=\"20\" height=\"12\" x=\"2\" y=\"6\" rx=\"2\"></rect><path d=\"M12 12h.01\"></path><path d=\"M17 12h.01\"></path><path d=\"M7 12h.01\"></path></svg></div><div class=\"flex-1 min-w-0\"><div class=\"flex items-center gap-2 mb-1\"><h3 class=\"font-semibold text-white text-sm\">Form Input Labels</h3><span class=\"inline-flex items-center gap-1 text-[10px] font-medium text-white/40\"><span class=\"w-1.5 h-1.5 rounded-full bg-risk-medium\"></span>Often overlooked</span></div><p class=\"text-white/40 text-xs leading-relaxed\">Checks that every form field has a proper label — required for GDPR clarity and WCAG accessibility.</p></div></div></div></div><div class=\"reveal reveal-delay-3\"><div class=\"group glass rounded-2xl p-6 border border-white/[0.07] hover:border-white/[0.14] hover-lift transition-all h-full\"><div class=\"flex items-start gap-4\"><div class=\"flex-shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-xl\" style=\"background:rgba(245,158,11, 0.12);border:1px solid rgba(245,158,11, 0.2)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-scale w-5 h-5\" aria-hidden=\"true\" style=\"color:#f59e0b\"><path d=\"M12 3v18\"></path><path d=\"m19 8 3 8a5 5 0 0 1-6 0zV7\"></path><path d=\"M3 7h1a17 17 0 0 0 8-2 17 17 0 0 0 8 2h1\"></path><path d=\"m5 8 3 8a5 5 0 0 1-6 0zV7\"></path><path d=\"M7 21h10\"></path></svg></div><div class=\"flex-1 min-w-0\"><div class=\"flex items-center gap-2 mb-1\"><h3 class=\"font-semibold text-white text-sm\">Third-Party Embeds</h3><span class=\"inline-flex items-center gap-1 text-[10px] font-medium text-white/40\"><span class=\"w-1.5 h-1.5 rounded-full bg-risk-medium\"></span>Often overlooked</span></div><p class=\"text-white/40 text-xs leading-relaxed\">Reviews YouTube, Twitter, and other embeds to ensure they don&#x27;t load tracking content before consent.</p></div></div></div></div></div><div class=\"reveal reveal-delay-2 mt-8 text-center\"><p class=\"text-white/25 text-xs\">Plus: form action transparency, COPPA indicators, CCPA opt-out mechanisms, data retention disclosures, and more.</p></div></div></section><section id=\"pricing\" class=\"py-28 px-4 relative\"><div class=\"absolute inset-0 bg-gradient-to-b from-midnight-light/20 via-midnight to-midnight pointer-events-none\"></div><div class=\"mx-auto max-w-6xl relative z-10\"><div class=\"reveal  text-center mb-6\"><h2 class=\"font-heading text-3xl sm:text-4xl font-bold text-white mb-4\">Simple, Transparent Pricing</h2><p class=\"text-white/50 text-lg max-w-xl mx-auto\">Start free. Upgrade when you need the full report. No hidden fees, no sales calls.</p></div><div class=\"reveal reveal-delay-1 flex items-center justify-center gap-3 mb-16\"><div class=\"flex items-center gap-1.5 text-xs text-white/30\"><span class=\"w-2 h-2 rounded-full bg-risk-high\"></span>High risk</div><div class=\"h-1 w-24 rounded-full bg-gradient-to-r from-risk-high via-risk-medium to-risk-low opacity-40\"></div><div class=\"flex items-center gap-1.5 text-xs text-white/30\"><span class=\"w-2 h-2 rounded-full bg-risk-low\"></span>Compliant</div></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-16\"><div class=\"reveal reveal-delay-1\"><div class=\"relative glass rounded-2xl p-8 flex flex-col h-full transition-all hover-lift border-white/[0.07] \"><div class=\"mb-6\"><div class=\"flex items-center gap-2 mb-1\"><span class=\"w-2 h-2 rounded-full bg-white/30\"></span><h3 class=\"font-heading text-lg font-semibold text-white\">Free</h3></div><div class=\"flex items-baseline gap-1.5 mt-2\"><span class=\"font-heading text-5xl font-bold text-white\">$0</span><span class=\"text-white/40 text-sm\">forever</span></div><p class=\"text-white/40 text-sm mt-3 leading-relaxed\">See what&apos;s on your site before attackers or regulators do. Full issue breakdown, no credit card.</p></div><ul class=\"space-y-3 mb-8 flex-1\"><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>3 scans per month</span></li><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>Issue detection &amp; severity</span></li><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>AI-powered analysis</span></li><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>Basic fix suggestions</span></li><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>PDF report preview</span></li></ul><button class=\"w-full rounded-xl py-3.5 px-6 font-bold text-sm transition-all disabled:opacity-50 disabled:cursor-not-allowed hover-scale bg-white/[0.07] text-white hover:bg-white/[0.12] border border-white/[0.1]\">Scan Free</button></div></div><div class=\"reveal reveal-delay-2\"><div class=\"relative glass rounded-2xl p-8 flex flex-col h-full transition-all hover-lift border-accent-blue/30 shadow-glow-blue scale-[1.02]\"><div class=\"inline-flex items-center gap-1.5 rounded-full text-xs font-semibold px-3 py-1 mb-5 w-fit border bg-accent-blue/15 border-accent-blue/30 text-accent-blue\"><span class=\"w-1.5 h-1.5 rounded-full bg-current animate-pulse\"></span>Most Popular</div><div class=\"mb-6\"><div class=\"flex items-center gap-2 mb-1\"><span class=\"w-2 h-2 rounded-full bg-risk-medium\"></span><h3 class=\"font-heading text-lg font-semibold text-white\">Pro</h3></div><div class=\"flex items-baseline gap-1.5 mt-2\"><span class=\"font-heading text-5xl font-bold text-white\">$29</span><span class=\"text-white/40 text-sm\">per report</span></div><p class=\"text-white/40 text-sm mt-3 leading-relaxed\">The full picture — legal article references, executive summary, and step-by-step remediation.</p></div><ul class=\"space-y-3 mb-8 flex-1\"><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>Full PDF compliance report</span></li><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>Legal article references (GDPR, ePrivacy)</span></li><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>Detailed fix recommendations</span></li><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>Executive summary</span></li><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>Priority email support</span></li></ul><button class=\"w-full rounded-xl py-3.5 px-6 font-bold text-sm transition-all disabled:opacity-50 disabled:cursor-not-allowed hover-scale bg-accent-blue text-white hover:bg-accent-glow shadow-glow-blue\">Get PDF Report</button></div></div><div class=\"reveal reveal-delay-3\"><div class=\"relative glass rounded-2xl p-8 flex flex-col h-full transition-all hover-lift border-white/[0.07] \"><div class=\"mb-6\"><div class=\"flex items-center gap-2 mb-1\"><span class=\"w-2 h-2 rounded-full bg-white/30\"></span><h3 class=\"font-heading text-lg font-semibold text-white\">Agency</h3></div><div class=\"flex items-baseline gap-1.5 mt-2\"><span class=\"font-heading text-5xl font-bold text-white\">$99</span><span class=\"text-white/40 text-sm\">per month</span></div><p class=\"text-white/40 text-sm mt-3 leading-relaxed\">Unlimited scans for all your client websites. White-label reports and a client management dashboard.</p></div><ul class=\"space-y-3 mb-8 flex-1\"><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>Unlimited scans</span></li><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>White-label PDF reports</span></li><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>Manage up to 50 clients</span></li><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>Historical scan comparison</span></li><li class=\"flex items-start gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-check w-4 h-4 text-risk-low flex-shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"M20 6 9 17l-5-5\"></path></svg><span>Priority email support</span></li></ul><button class=\"w-full rounded-xl py-3.5 px-6 font-bold text-sm transition-all disabled:opacity-50 disabled:cursor-not-allowed hover-scale bg-white/[0.07] text-white hover:bg-white/[0.12] border border-white/[0.1]\">Start Agency</button></div></div></div><div class=\"reveal reveal-delay-2\"><div class=\"text-center mb-6\"><p class=\"text-white/30 text-xs uppercase tracking-widest mb-1\">See it in action</p><p class=\"text-white/50 text-sm\">Here&#x27;s what a real compliance report looks like</p></div><div class=\"glass rounded-2xl p-6 border border-white/10 hover-lift cursor-pointer max-w-sm mx-auto\"><div class=\"flex items-center justify-between mb-4\"><div class=\"flex items-center gap-2\"><div class=\"w-8 h-8 rounded-lg bg-risk-medium-bg border border-risk-medium-border flex items-center justify-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert w-4 h-4 text-risk-medium\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg></div><span class=\"text-sm font-medium text-white/70\">Sample Report</span></div><span class=\"text-xs text-white/30 hover:text-white/60 transition-colors\">See full report →</span></div><div class=\"flex items-center gap-4 mb-4\"><div class=\"relative w-20 h-20 flex-shrink-0\"><svg viewBox=\"0 0 80 80\" class=\"w-full h-full -rotate-90\"><circle cx=\"40\" cy=\"40\" r=\"32\" fill=\"none\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"6\"></circle><circle cx=\"40\" cy=\"40\" r=\"32\" fill=\"none\" stroke=\"#f59e0b\" stroke-width=\"6\" stroke-dasharray=\"136.72211228422782 201.06192982974676\" stroke-linecap=\"round\" class=\"transition-all duration-700\" style=\"filter:drop-shadow(0 0 6px rgba(245,158,11,0.5))\"></circle></svg><div class=\"absolute inset-0 flex flex-col items-center justify-center\"><span class=\"text-xl font-bold text-risk-medium\">68</span><span class=\"text-[9px] text-white/40 uppercase tracking-wider\">Score</span></div></div><div><div class=\"inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 bg-risk-medium-bg border border-risk-medium-border mb-1.5\"><span class=\"w-1.5 h-1.5 rounded-full bg-risk-medium animate-pulse\"></span><span class=\"text-xs font-semibold text-risk-medium\">MEDIUM RISK</span></div><p class=\"text-sm text-white/50\">example.com</p><p class=\"text-xs text-white/30\">4 issues found</p></div></div><div class=\"space-y-2 mb-4\"><div class=\"flex items-center gap-2.5 text-sm\"><div class=\"w-5 h-5 rounded flex items-center justify-center flex-shrink-0 bg-risk-high-bg\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert w-3 h-3 text-risk-high\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg></div><span class=\"text-white/60\">Cookie banner missing</span><span class=\"ml-auto text-[10px] font-semibold uppercase tracking-wider text-risk-high\">high</span></div><div class=\"flex items-center gap-2.5 text-sm\"><div class=\"w-5 h-5 rounded flex items-center justify-center flex-shrink-0 bg-risk-high-bg\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert w-3 h-3 text-risk-high\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg></div><span class=\"text-white/60\">No privacy policy page</span><span class=\"ml-auto text-[10px] font-semibold uppercase tracking-wider text-risk-high\">high</span></div><div class=\"flex items-center gap-2.5 text-sm\"><div class=\"w-5 h-5 rounded flex items-center justify-center flex-shrink-0 bg-risk-low-bg\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check-big w-3 h-3 text-risk-low\" aria-hidden=\"true\"><path d=\"M21.801 10A10 10 0 1 1 17 3.335\"></path><path d=\"m9 11 3 3L22 4\"></path></svg></div><span class=\"text-white/60\">SSL/HTTPS active</span><span class=\"ml-auto text-[10px] font-semibold uppercase tracking-wider text-risk-low\">low</span></div><div class=\"flex items-center gap-2.5 text-sm\"><div class=\"w-5 h-5 rounded flex items-center justify-center flex-shrink-0 bg-risk-medium-bg\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert w-3 h-3 text-risk-medium\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg></div><span class=\"text-white/60\">Tracking scripts need review</span><span class=\"ml-auto text-[10px] font-semibold uppercase tracking-wider text-risk-medium\">medium</span></div></div><button class=\"w-full mt-4 rounded-lg border border-accent-blue/30 text-accent-blue text-sm font-semibold py-2.5 hover:bg-accent-blue/10 hover:border-accent-blue/50 transition-all flex items-center justify-center gap-1.5 group\">Try it on your site — free<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg></button></div></div></div></section><section id=\"faq\" class=\"py-28 px-4 relative\"><div class=\"absolute inset-0 bg-gradient-to-b from-midnight via-midnight to-midnight-light/20 pointer-events-none\"></div><div class=\"mx-auto max-w-3xl relative z-10\"><div class=\"reveal  text-center mb-16\"><h2 class=\"font-heading text-3xl sm:text-4xl font-bold text-white mb-4\">Frequently Asked Questions</h2><p class=\"text-white/50 text-lg\">Everything you need to know before scanning your site.</p></div><div class=\"space-y-3\"><div class=\"reveal reveal-delay-1\"><div class=\"glass rounded-2xl overflow-hidden border border-white/[0.06] hover:border-white/[0.1] transition-colors\"><button class=\"w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-white/[0.02] transition-colors\"><span class=\"font-medium text-white text-sm\">How does the scan work?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-4 h-4 text-white/40 flex-shrink-0 transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-300 ease-in-out max-h-0\"><div class=\"px-6 pb-5\"><div class=\"w-full h-px bg-white/[0.06] mb-4\"></div><p class=\"text-white/50 text-sm leading-relaxed\">Our system uses an automated crawler to visit your website, analyze the HTML, meta tags, cookie banners, privacy policy links, and third-party scripts. The results are then processed through our AI analysis engine to identify GDPR compliance gaps.</p></div></div></div></div><div class=\"reveal reveal-delay-2\"><div class=\"glass rounded-2xl overflow-hidden border border-white/[0.06] hover:border-white/[0.1] transition-colors\"><button class=\"w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-white/[0.02] transition-colors\"><span class=\"font-medium text-white text-sm\">Is my URL stored?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-4 h-4 text-white/40 flex-shrink-0 transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-300 ease-in-out max-h-0\"><div class=\"px-6 pb-5\"><div class=\"w-full h-px bg-white/[0.06] mb-4\"></div><p class=\"text-white/50 text-sm leading-relaxed\">Your URL is processed to perform the scan and is stored only as part of your scan history if you purchase a report. We do not share your URL with third parties, and it is not made publicly accessible. Scan data is retained for 30 days then automatically deleted.</p></div></div></div></div><div class=\"reveal reveal-delay-3\"><div class=\"glass rounded-2xl overflow-hidden border border-white/[0.06] hover:border-white/[0.1] transition-colors\"><button class=\"w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-white/[0.02] transition-colors\"><span class=\"font-medium text-white text-sm\">What happens after payment?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-4 h-4 text-white/40 flex-shrink-0 transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-300 ease-in-out max-h-0\"><div class=\"px-6 pb-5\"><div class=\"w-full h-px bg-white/[0.06] mb-4\"></div><p class=\"text-white/50 text-sm leading-relaxed\">After successful payment, your scan is automatically triggered and typically completes within 2 minutes. A PDF report is then emailed to you with a detailed breakdown of every compliance issue found, its severity, and actionable fix recommendations.</p></div></div></div></div><div class=\"reveal reveal-delay-1\"><div class=\"glass rounded-2xl overflow-hidden border border-white/[0.06] hover:border-white/[0.1] transition-colors\"><button class=\"w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-white/[0.02] transition-colors\"><span class=\"font-medium text-white text-sm\">Can I get a refund?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-4 h-4 text-white/40 flex-shrink-0 transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-300 ease-in-out max-h-0\"><div class=\"px-6 pb-5\"><div class=\"w-full h-px bg-white/[0.06] mb-4\"></div><p class=\"text-white/50 text-sm leading-relaxed\">If your scan completes but returns no findings (blank report), we offer a full refund. If you are unsatisfied with the report for any reason within 7 days of purchase, contact our support team and we will work to resolve your concern.</p></div></div></div></div><div class=\"reveal reveal-delay-2\"><div class=\"glass rounded-2xl overflow-hidden border border-white/[0.06] hover:border-white/[0.1] transition-colors\"><button class=\"w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-white/[0.02] transition-colors\"><span class=\"font-medium text-white text-sm\">Is this suitable for EU websites only?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-4 h-4 text-white/40 flex-shrink-0 transition-transform duration-200\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden transition-all duration-300 ease-in-out max-h-0\"><div class=\"px-6 pb-5\"><div class=\"w-full h-px bg-white/[0.06] mb-4\"></div><p class=\"text-white/50 text-sm leading-relaxed\">GDPR applies to any website that collects data from or targets users in the European Union, regardless of where your business is based. ComplyScan is designed to audit against GDPR requirements specifically, which is the strictest privacy regulation globally. If you are compliant with GDPR, you will be well positioned for other regulations like CCPA.</p></div></div></div></div></div></div></section><footer id=\"contact\" class=\"border-t border-white/10 bg-midnight\"><div class=\"mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12\"><div class=\"flex flex-col md:flex-row items-center justify-between gap-6\"><div class=\"text-center md:text-left\"><a class=\"font-heading text-xl font-bold text-white hover:text-accent-glow transition-colors\" href=\"/\">ComplyScan</a><p class=\"text-white/40 text-sm mt-1\">GDPR compliance made effortless.</p></div><nav class=\"flex flex-wrap items-center justify-center gap-6\"><a class=\"text-sm text-white/50 hover:text-white transition-colors\" href=\"/legal/privacy\">Privacy Policy</a><a class=\"text-sm text-white/50 hover:text-white transition-colors\" href=\"/legal/terms\">Terms of Service</a><a class=\"text-sm text-white/50 hover:text-white transition-colors\" href=\"/blog\">Blog</a></nav></div><div class=\"mt-8 pt-8 border-t border-white/5 text-center\"><p class=\"text-white/30 text-sm\">© 2026 ComplyScan. All rights reserved.</p></div></div></footer></main><!--$--><!--/$--><script src=\"/_next/static/chunks/webpack-e6846760208f1794.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[7555,[],\\\"\\\"]\\n3:I[1295,[],\\\"\\\"]\\n4:I[8657,[\\\"874\\\",\\\"static/chunks/874-437a265a67d6cfee.js\\\",\\\"267\\\",\\\"static/chunks/267-4241c65e6763c9ec.js\\\",\\\"974\\\",\\\"static/chunks/app/page-e3ffd174d03c09e3.js\\\"],\\\"Navbar\\\"]\\n5:I[5950,[\\\"874\\\",\\\"static/chunks/874-437a265a67d6cfee.js\\\",\\\"267\\\",\\\"static/chunks/267-4241c65e6763c9ec.js\\\",\\\"974\\\",\\\"static/chunks/app/page-e3ffd174d03c09e3.js\\\"],\\\"Hero\\\"]\\n6:I[7734,[\\\"874\\\",\\\"static/chunks/874-437a265a67d6cfee.js\\\",\\\"267\\\",\\\"static/chunks/267-4241c65e6763c9ec.js\\\",\\\"974\\\",\\\"static/chunks/app/page-e3ffd174d03c09e3.js\\\"],\\\"HowItWorks\\\"]\\n7:I[1075,[\\\"874\\\",\\\"static/chunks/874-437a265a67d6cfee.js\\\",\\\"267\\\",\\\"static/chunks/267-4241c65e6763c9ec.js\\\",\\\"974\\\",\\\"static/chunks/app/page-e3ffd174d03c09e3.js\\\"],\\\"WhatWeCheck\\\"]\\n8:I[7033,[\\\"874\\\